rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Catálogo de productos:
    //  - Cualquiera puede LEER (para mostrar el catálogo en el sitio).
    //  - Solo el administrador autenticado puede ESCRIBIR (crear/editar/borrar).
    match /products/{doc} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == "ventasquito.soporte@gmail.com";
    }

    // Categorías del catálogo: lectura pública, escritura solo del administrador.
    match /categories/{doc} {
      allow read: if true;
      allow write: if request.auth != null
                   && request.auth.token.email == "ventasquito.soporte@gmail.com";
    }

    // Todo lo demás queda bloqueado por defecto.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
